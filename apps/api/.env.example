# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://Noblesse:Noblesse_pass@localhost:5432/Noblesse_pms?schema=public"

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Noblesse PMS <noreply@Noblessepms.com>"

# ─── File Storage ─────────────────────────────────────────────
STORAGE_PROVIDER=local
# For S3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=Noblesse-pms

# ─── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Swagger ──────────────────────────────────────────────────
SWAGGER_ENABLED=true